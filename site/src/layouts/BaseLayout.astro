---
import GitHubIcon from "../components/GitHubIcon.astro";
import { buildStructuredData, siteName, socialImageUrl } from "../seo";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  robots?: string;
  structuredData?: object | object[];
}

const {
  title = "Memory by Aictx - The Product Graph for AI Coding Agents",
  description = "Memory keeps the product graph of a codebase: features, decisions, status — anchored to the code. Agents query it on demand and keep it current as the product changes.",
  ogType = "website",
  robots,
  structuredData
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://memory.aictx.dev");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImage = socialImageUrl(siteUrl);
const demoViewerUrl = "https://demo.aictx.dev/?token=demo";
const websiteJsonLd = buildStructuredData(siteUrl);
const structuredDataItems = [
  websiteJsonLd,
  ...(Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [])
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Memory by Aictx product graph overview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="Memory by Aictx product graph overview" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    {
      structuredDataItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)}></script>
      ))
    }
    <script src="/stars.js" defer></script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Memory home">
        <img class="brand-mark" src="/assets/logo/memory-constellation-logo.svg" width="34" height="34" alt="" aria-hidden="true" />
        <span>Memory</span>
      </a>

      <nav aria-label="Primary navigation">
        <a href={demoViewerUrl} rel="noreferrer">Demo Viewer</a>
        <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
      </nav>

      <details class="mobile-menu">
        <summary aria-label="Open navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-menu-panel">
          <a href={demoViewerUrl} rel="noreferrer">Demo Viewer</a>
          <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
          <a href="https://github.com/aictx/memory" rel="noreferrer">GitHub</a>
        </div>
      </details>

      <a class="github-pill" href="https://github.com/aictx/memory" rel="noreferrer">
        <GitHubIcon />
        <span>GitHub</span>
        <strong data-star-count="compact"></strong>
      </a>
    </header>

    <slot />

    <footer class="site-footer">
      <div>
        <strong>Memory by Aictx</strong>
        <p>The product graph of your codebase, kept local and reviewable in Git.</p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
        <a href={demoViewerUrl} rel="noreferrer">Demo Viewer</a>
        <a href="https://github.com/aictx/memory" rel="noreferrer">GitHub</a>
        <a href="mailto:michele@remics.tech">Contact us</a>
      </nav>
    </footer>
  </body>
</html>
