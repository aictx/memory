{
  "$id": "https://aictx.dev/schemas/v5/config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "memory": {
      "additionalProperties": false,
      "properties": {
        "autoIndex": {
          "type": "boolean"
        },
        "defaultTokenBudget": {
          "maximum": 50000,
          "minimum": 501,
          "type": "integer"
        }
      },
      "required": [
        "defaultTokenBudget",
        "autoIndex"
      ],
      "type": "object"
    },
    "project": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^project\\.[a-z0-9][a-z0-9-]*$",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "type": "object"
    },
    "version": {
      "enum": [
        5
      ]
    }
  },
  "required": [
    "version",
    "project",
    "memory"
  ],
  "type": "object"
}
